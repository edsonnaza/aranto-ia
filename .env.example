# Docker Environment Variables
# Copy this file to .env and fill in your values
# Para desarrollo local, estos valores ya funcionan listos para usar

# Database Configuration
MYSQL_ROOT_PASSWORD= 
MYSQL_DATABASE=aranto_medical
MYSQL_USER=aranto_user
MYSQL_PASSWORD= 
DB_HOST=mysql
DB_PORT=3306

# Redis Configuration
REDIS_HOST=redis
REDIS_PASSWORD=
